# ── AussieBarbers environment variables ──────────────────────────────
# Copy this file to `.env.local` and fill in the values.
# In production, set these in Vercel → Project → Settings → Environment Variables.

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (Developers → API keys)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# From the Stripe webhook you create (Developers → Webhooks)
STRIPE_WEBHOOK_SECRET=

# Public site URL (used for redirects)
NEXT_PUBLIC_SITE_URL=https://aussiebarbers.com.au

# Passcode that locks /admin and /dashboard. Pick a strong secret.
ADMIN_PASSCODE=
